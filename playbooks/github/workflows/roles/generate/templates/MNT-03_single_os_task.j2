---
name: "{{ tp_consolidated_workflow.name }}"

{% if tp_env == "main" %}
on:
  repository_dispatch:
    types: [generate_workflow]

  workflow_dispatch:

jobs:
  display_default_usage:
    name: Display default usage
    runs-on:
      - self-hosted
      - base-runner
    steps:
      - name: Display usage
        shell: bash
        run: |
          echo "================================================================================"
          echo " Usage: Select from the branches drop-down the environment you want to deploy!! "
          echo "================================================================================"
{% else %}
on:
  workflow_dispatch:
    inputs:
      namespace:
        description: "The deployment namespace (alias)"
        required: true
        type: choice
        options:
{% for _namespace in tp_consolidated_workflow.tp_namespaces %}
          - "{{ _namespace }}"
{% endfor %}
      region:
        description: "The deployment region"
        required: true
        type: choice
        options:
{% for _region in tp_consolidated_workflow.tp_regions %}
          - "{{ _region }}"
{% endfor %}
      tp_env:
        description: "The deployment environment"
        required: true
        type: choice
        options:
          - "{{ tp_consolidated_workflow.tp_env }}"
      node_types:
        description: "The deployment node types"
        required: true
        type: choice
        options:
{% for _node_type in tp_consolidated_workflow.tp_node_types %}
          - "{{ _node_type }}"
{% endfor %}
      run_this_task:
        description: "Run this OS Config task. 'main' will run all eligible."
        required: true
        default: "__Select_One__"
        type: choice
        options:
          - "__Select_One__"
          - "all"
          - "add_packages"
          - "check_kernel_version_demo"
          - "configure_auditd"
          - "configure_apt_repos"
          - "configure_crowdstrike"
          - "configure_dns"
          - "configure_filesystems"
          - "configure_generic_items"
          - "configure_groups"
          - "configure_http_proxy"
          - "configure_insights"
          - "configure_ldap_client"
          - "configure_motd"
          - "configure_nagios"
          - "configure_nic_tuning"
          - "configure_ntp_chrony"
          - "configure_satellite_registration"
          - "configure_security_items"
          - "configure_security_items_redhat7"
          - "configure_security_items_redhat8"
          - "configure_selinux"
          - "configure_snmp"
          - "configure_splunk_uf"
          - "configure_sudoers"
          - "configure_swap"
          - "configure_svc_disco"
          - "configure_timezone"
          - "configure_tripwire"
          - "configure_waagent"
          - "demo_os_task"
          - "demo_redhat_6_task"
          - "demo_redhat_7_task"
          - "demo_redhat_8_task"
          - "demo_redhat_os_family_task"
          - "disable_copilot"
          - "remove_trendmicro"
          - "remove_crowdstrike"
          - "remove_waagent"
          - "upgrade_all_packages"
          - "upgrade_prep_and_download"
      inventories_branch:
        description: "Override the inventory repository branch"
        required: false
        type: string
        default: "main"
      limits:
        description: "Limit - Leave blank for no limits, or --limit= plus a comma delimited string of nodes to action"
        required: false
        type: string
      extra_vars:
        description: "Extra Vars - Leave blank, or --extra-vars \"foo=bar\""
        required: false
        type: string
      ansible_debug:
        description: "Choose Ansible Debug Level"
        required: false
        default: '-v'
        type: string

jobs:
  call_run_os_config_task:
    name: "Run OS Config Task"
    uses: "Tvlport-IAAS/iaas-workflows/.github/workflows/run_os_config_task_wf.yml@main"
    with:
      namespace: "{% raw %}${{ inputs.namespace }}{% endraw %}"
      region: "{% raw %}${{ inputs.region }}{% endraw %}"
      tp_env: "{% raw %}${{ inputs.tp_env }}{% endraw %}"
      node_types: "{% raw %}${{ inputs.node_types }}{% endraw %}"
      inventories_branch: "{% raw %}${{ inputs.inventories_branch }}{% endraw %}"
      run_this_task: "{% raw %}${{ inputs.run_this_task }}{% endraw %}"
      limits: "{% raw %}${{ inputs.limits }}{% endraw %}"
      extra_vars: "{% raw %}${{ inputs.extra_vars }}{% endraw %}"
      ansible_debug: "{% raw %}${{ inputs.ansible_debug }}{% endraw %}"

    secrets:
      token: "{% raw %}${{ secrets.IAAS_WORKFLOWS_PAT }}{% endraw %}"
      ssh_private_key: "{% raw %}${{ secrets.IAASOPS_SSH_PRIVATE_KEY }}{% endraw %}"
      ansible_vault_key: "{% raw %}${{ secrets.ANSIBLE_VAULT_KEY }}{% endraw %}"
{% endif %}
