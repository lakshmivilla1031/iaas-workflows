{
  "problemMatcher": [
    {
      "owner": "bash-action",
      "pattern": [
        {
          "regexp": "^(FATAL|ALERT|INFO):\\s(.+),\\sline\\s(\\d+):\\s(.+)$",
          "file": 2,
          "line": 3,
          "severity": 1,
          "message": 4
        }
      ]
    }
  ]
}